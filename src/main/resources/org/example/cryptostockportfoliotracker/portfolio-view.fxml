<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.cryptostockportfoliotracker.controller.PortfolioController"
            stylesheets="@portfolio-theme.css"
            styleClass="app-root"
            prefHeight="760.0"
            prefWidth="1200.0">

    <top>
        <VBox spacing="12.0" styleClass="hero-panel">
            <Label text="Digital Portfolio Tracker" styleClass="hero-title" />
            <Label text="Track stock and crypto buys, sells, history and portfolio performance."
                   styleClass="hero-subtitle" />

            <GridPane hgap="10.0" vgap="10.0" styleClass="form-grid">
                <padding>
                    <Insets top="8.0" right="0.0" bottom="4.0" left="0.0" />
                </padding>

                <Label text="Investor" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="investorField" editable="false" promptText="Investor name" styleClass="form-input read-only-field" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Asset Symbol" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <TextField fx:id="assetField" promptText="BTC / AAPL" styleClass="form-input" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                <Label text="Asset Name" styleClass="form-label" GridPane.columnIndex="4" GridPane.rowIndex="0" />
                <TextField fx:id="assetNameField" promptText="Bitcoin / Apple" styleClass="form-input" GridPane.columnIndex="5" GridPane.rowIndex="0" />

                <Label text="Category" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <ComboBox fx:id="categoryBox" prefWidth="150.0" styleClass="form-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Type" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <ComboBox fx:id="typeBox" prefWidth="150.0" styleClass="form-input" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                <Label text="Quantity" styleClass="form-label" GridPane.columnIndex="4" GridPane.rowIndex="1" />
                <TextField fx:id="quantityField" promptText="0.00" styleClass="form-input" GridPane.columnIndex="5" GridPane.rowIndex="1" />

                <Label text="Unit Price" styleClass="form-label" GridPane.columnIndex="6" GridPane.rowIndex="1" />
                <TextField fx:id="priceField" promptText="0.00" styleClass="form-input" GridPane.columnIndex="7" GridPane.rowIndex="1" />

                <Button text="Record Transaction"
                        onAction="#addTransaction"
                        styleClass="primary-button"
                        GridPane.columnIndex="8"
                        GridPane.rowIndex="1" />
            </GridPane>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.58" styleClass="content-split">
            <VBox spacing="10.0" styleClass="panel">
                <Label text="Transaction History" styleClass="section-title" />
                <TableView fx:id="transactionTable" prefHeight="460.0" styleClass="data-table">
                    <columns>
                        <TableColumn fx:id="txDateColumn" prefWidth="95.0" text="Date" />
                        <TableColumn fx:id="txSymbolColumn" prefWidth="85.0" text="Symbol" />
                        <TableColumn fx:id="txNameColumn" prefWidth="130.0" text="Name" />
                        <TableColumn fx:id="txCategoryColumn" prefWidth="90.0" text="Category" />
                        <TableColumn fx:id="txTypeColumn" prefWidth="80.0" text="Type" />
                        <TableColumn fx:id="txQuantityColumn" prefWidth="90.0" text="Quantity" />
                        <TableColumn fx:id="txPriceColumn" prefWidth="95.0" text="Unit Price" />
                        <TableColumn fx:id="txTotalColumn" prefWidth="100.0" text="Total" />
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="10.0" styleClass="panel alt-panel">
                <Label text="Current Holdings" styleClass="section-title" />
                <TableView fx:id="holdingsTable" prefHeight="320.0" styleClass="data-table">
                    <columns>
                        <TableColumn fx:id="holdingSymbolColumn" prefWidth="80.0" text="Symbol" />
                        <TableColumn fx:id="holdingNameColumn" prefWidth="120.0" text="Name" />
                        <TableColumn fx:id="holdingCategoryColumn" prefWidth="90.0" text="Category" />
                        <TableColumn fx:id="holdingQuantityColumn" prefWidth="90.0" text="Quantity" />
                        <TableColumn fx:id="holdingAvgCostColumn" prefWidth="95.0" text="Avg Cost" />
                        <TableColumn fx:id="holdingCurrentPriceColumn" prefWidth="95.0" text="Current Price" />
                        <TableColumn fx:id="holdingValueColumn" prefWidth="95.0" text="Value" />
                        <TableColumn fx:id="holdingPnlColumn" prefWidth="105.0" text="Unrealized P/L" />
                    </columns>
                </TableView>

                <VBox spacing="10.0" styleClass="summary-card">
                    <Label text="Portfolio Summary" styleClass="summary-title" />
                    <HBox spacing="18.0" styleClass="summary-row">
                        <Label fx:id="totalInvestedLabel" text="Total Invested: $0.00" styleClass="summary-label" />
                        <Label fx:id="portfolioValueLabel" text="Portfolio Value: $0.00" styleClass="summary-label" />
                    </HBox>
                    <HBox spacing="18.0" styleClass="summary-row">
                        <Label fx:id="realizedProfitLabel" text="Realized P/L: $0.00" styleClass="summary-label" />
                        <Label fx:id="unrealizedProfitLabel" text="Unrealized P/L: $0.00" styleClass="summary-label" />
                    </HBox>
                    <Label fx:id="totalProfitLossLabel" text="Total P/L: $0.00" styleClass="summary-total" />
                </VBox>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
