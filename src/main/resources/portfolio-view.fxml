<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.cryptostockportfoliotracker.controller.PortfolioController"
            prefHeight="760.0"
            prefWidth="1200.0">

    <top>
        <VBox spacing="12.0" style="-fx-padding: 18; -fx-background-color: linear-gradient(to right, #13293d, #1b4965);">
            <Label text="Digital Portfolio Tracker" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Label text="Track stock and crypto buys, sells, history and portfolio performance."
                   style="-fx-text-fill: #d9e6f2; -fx-font-size: 13px;" />

            <GridPane hgap="10.0" vgap="10.0">
                <padding>
                    <Insets top="8.0" right="0.0" bottom="4.0" left="0.0" />
                </padding>

                <Label text="Investor" style="-fx-text-fill: white;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="investorField" editable="false" promptText="Investor name" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Asset Symbol" style="-fx-text-fill: white;" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <TextField fx:id="assetField" promptText="BTC / AAPL" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                <Label text="Asset Name" style="-fx-text-fill: white;" GridPane.columnIndex="4" GridPane.rowIndex="0" />
                <TextField fx:id="assetNameField" promptText="Bitcoin / Apple" GridPane.columnIndex="5" GridPane.rowIndex="0" />

                <Label text="Category" style="-fx-text-fill: white;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <ComboBox fx:id="categoryBox" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Type" style="-fx-text-fill: white;" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <ComboBox fx:id="typeBox" prefWidth="150.0" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                <Label text="Quantity" style="-fx-text-fill: white;" GridPane.columnIndex="4" GridPane.rowIndex="1" />
                <TextField fx:id="quantityField" promptText="0.00" GridPane.columnIndex="5" GridPane.rowIndex="1" />

                <Label text="Unit Price" style="-fx-text-fill: white;" GridPane.columnIndex="6" GridPane.rowIndex="1" />
                <TextField fx:id="priceField" promptText="0.00" GridPane.columnIndex="7" GridPane.rowIndex="1" />

                <Button text="Record Transaction"
                        onAction="#addTransaction"
                        style="-fx-background-color: #f4d35e; -fx-font-weight: bold;"
                        GridPane.columnIndex="8"
                        GridPane.rowIndex="1" />
            </GridPane>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.58">
            <VBox spacing="10.0" style="-fx-padding: 16;">
                <Label text="Transaction History" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <TableView fx:id="transactionTable" prefHeight="460.0">
                    <columns>
                        <TableColumn fx:id="txDateColumn" prefWidth="95.0" text="Date" />
                        <TableColumn fx:id="txSymbolColumn" prefWidth="85.0" text="Symbol" />
                        <TableColumn fx:id="txNameColumn" prefWidth="130.0" text="Name" />
                        <TableColumn fx:id="txCategoryColumn" prefWidth="90.0" text="Category" />
                        <TableColumn fx:id="txTypeColumn" prefWidth="80.0" text="Type" />
                        <TableColumn fx:id="txQuantityColumn" prefWidth="90.0" text="Quantity" />
                        <TableColumn fx:id="txPriceColumn" prefWidth="95.0" text="Unit Price" />
                        <TableColumn fx:id="txTotalColumn" prefWidth="100.0" text="Total" />
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="10.0" style="-fx-padding: 16; -fx-background-color: #f8fbff;">
                <Label text="Current Holdings" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <TableView fx:id="holdingsTable" prefHeight="320.0">
                    <columns>
                        <TableColumn fx:id="holdingSymbolColumn" prefWidth="80.0" text="Symbol" />
                        <TableColumn fx:id="holdingNameColumn" prefWidth="120.0" text="Name" />
                        <TableColumn fx:id="holdingCategoryColumn" prefWidth="90.0" text="Category" />
                        <TableColumn fx:id="holdingQuantityColumn" prefWidth="90.0" text="Quantity" />
                        <TableColumn fx:id="holdingAvgCostColumn" prefWidth="95.0" text="Avg Cost" />
                        <TableColumn fx:id="holdingCurrentPriceColumn" prefWidth="95.0" text="Current Price" />
                        <TableColumn fx:id="holdingValueColumn" prefWidth="95.0" text="Value" />
                        <TableColumn fx:id="holdingPnlColumn" prefWidth="105.0" text="Unrealized P/L" />
                    </columns>
                </TableView>

                <VBox spacing="10.0" style="-fx-padding: 14; -fx-background-color: white; -fx-border-color: #d9e2ec; -fx-border-radius: 6; -fx-background-radius: 6;">
                    <Label text="Portfolio Summary" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                    <HBox spacing="18.0">
                        <Label fx:id="totalInvestedLabel" text="Total Invested: $0.00" />
                        <Label fx:id="portfolioValueLabel" text="Portfolio Value: $0.00" />
                    </HBox>
                    <HBox spacing="18.0">
                        <Label fx:id="realizedProfitLabel" text="Realized P/L: $0.00" />
                        <Label fx:id="unrealizedProfitLabel" text="Unrealized P/L: $0.00" />
                    </HBox>
                    <Label fx:id="totalProfitLossLabel" text="Total P/L: $0.00" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                </VBox>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
